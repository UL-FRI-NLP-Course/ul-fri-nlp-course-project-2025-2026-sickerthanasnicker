# Copy these values to the repository-root .env file.
# Do not commit real API keys.

EVAL_PROVIDER=ollama
EVAL_MODEL=llama3:latest
JUDGE_PROVIDER=ollama
JUDGE_MODEL=llama3:latest
OLLAMA_HOST=http://localhost:11434
# Alias also supported:
# OLLAMA_URL=http://localhost:11434

# Optional Open WebUI support.
WEBUI_HOST=https://your-open-webui.example.com
WEBUI_API_KEY=replace-with-your-key
# Aliases also supported:
# OPENWEBUI_URL=https://your-open-webui.example.com
# OPENWEBUI_API_KEY=replace-with-your-key

# Optional OpenAI support.
OPENAI_API_KEY=replace-with-your-key
